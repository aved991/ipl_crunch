          <datasource-dependencies datasource='federated.1btu2s70uklqwo1et0xel1u0xmwb'>
            <column caption='Phase' datatype='string' name='[Calculation_1536290428819038208]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [over]&lt;=6 THEN &quot;PowerPlay&quot;&#13;&#10;ELSEif  [over]&gt;=6 AND [over]&lt;=15 THEN &quot;Middle Overs&quot;&#13;&#10;ELSE &quot;Death Overs&quot;&#13;&#10;END' />
            </column>
            <column caption='Batting&amp;win' datatype='string' name='[Calculation_1536290428822228994]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [batting_team]=[winner]&#13;&#10;then &quot;Winning Team&quot;&#13;&#10;else &quot;Losing Team&quot;&#13;&#10;END' />
            </column>
            <column caption='Phase Runs' datatype='integer' name='[Calculation_1536290428823941124]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [match_id], [batting_team], [Calculation_1536290428819038208] : SUM([runs_total]) }' />
            </column>
