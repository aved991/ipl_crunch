      <column caption='Toss Result(winner)' datatype='string' name='[Calculation_1536290428819918849]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [toss_winner] =[winner]&#13;&#10;THEN &quot;Toss Winner Won Match&quot;&#13;&#10;ELSE &quot;Toss Winner Lost Match&quot;&#13;&#10;END' />
      </column>
      <column caption='Batting&amp;win' datatype='string' name='[Calculation_1536290428822228994]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [batting_team]=[winner]&#13;&#10;then &quot;Winning Team&quot;&#13;&#10;else &quot;Losing Team&quot;&#13;&#10;END' />
      </column>
      <column caption='MatchPhaseID' datatype='string' name='[Calculation_1536290428823597059]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR([match_id]) + &quot;-&quot; + [Calculation_1536290428819038208] + &quot;-&quot; + [batting_team]' />
      </column>
      <column caption='Phase Runs' datatype='integer' name='[Calculation_1536290428823941124]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [match_id], [batting_team], [Calculation_1536290428819038208] : SUM([runs_total]) }' />
      </column>
      <column caption='Wickets' datatype='integer' name='[Calculation_1536290429327556613]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [wicket_kind] != &quot;run out&quot;&#13;&#10;AND [wicket_kind] != &quot;retired hurt&quot;&#13;&#10;AND NOT ISNULL([wicket_kind])&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
